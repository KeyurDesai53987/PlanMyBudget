{
  "name": "saveit-budget-app",
  "productName": "SaveIt",
  "private": true,
  "version": "1.0.0",
  "description": "Personal Finance Tracker",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:web": "cd saveit-web && npm run build",
    "build": "npm run build:web && electron-builder --mac",
    "pack": "npm run build:web && electron-builder --dir"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.saveit.app",
    "productName": "SaveIt",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "api/**/*",
      "saveit-web/dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron.js"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": "dmg",
      "icon": "saveit-web/public/icon.icns"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeyurDesai53987/SaveIt.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KeyurDesai53987/SaveIt/issues"
  },
  "homepage": "https://github.com/KeyurDesai53987/SaveIt#readme"
}
