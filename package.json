{
  "name": "planmybudget-app",
  "productName": "PlanMyBudget",
  "private": true,
  "version": "1.0.0",
  "description": "Personal Finance Tracker",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:web": "cd saveit-web && npm run build",
    "build:electron": "npm run build:web && electron-builder --mac",
    "build": "npm run build:web"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.planmybudget.app",
    "productName": "PlanMyBudget",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "api/**/*",
      "saveit-web/dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron.js"
    },
    "publish": {
      "provider": "github",
      "owner": "KeyurDesai53987",
      "repo": "SaveIt"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": "dmg",
      "icon": "saveit-web/public/icon.icns"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeyurDesai53987/SaveIt.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KeyurDesai53987/SaveIt/issues"
  },
  "homepage": "https://github.com/KeyurDesai53987/SaveIt#readme"
}
