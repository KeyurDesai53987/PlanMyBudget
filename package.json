{
  "name": "planmybudget-app",
  "productName": "PlanMyBudget",
  "private": true,
  "version": "1.1.0",
  "description": "Personal Finance Tracker",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:web": "cd planmybudget-web && npm run build",
    "build:electron": "npm run build:web && electron-builder --mac",
    "build": "npm run build:web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.3",
    "pg": "^8.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.planmybudget.app",
    "productName": "PlanMyBudget",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "preload.js",
      "api/**/*",
      "planmybudget-web/dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron.js"
    },
    "publish": {
      "provider": "github",
      "owner": "KeyurDesai53987",
      "repo": "PlanMyBudget"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": "dmg",
      "icon": "planmybudget-web/public/icons/PlanMyBudget.icns"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeyurDesai53987/PlanMyBudget.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KeyurDesai53987/PlanMyBudget/issues"
  },
  "homepage": "https://github.com/KeyurDesai53987/PlanMyBudget#readme"
}
